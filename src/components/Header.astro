---
const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '博客' },
  { href: '/archive', label: '归档' },
  { href: '/about', label: '关于' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-hyouka-cream/80 dark:bg-gray-950/80 backdrop-blur-md border-b border-hyouka-mist/30 dark:border-gray-800/30">
  <nav class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-hyouka-sakura text-xl">🌸</span>
      <span class="font-serif text-lg font-bold text-hyouka-ink dark:text-gray-100 group-hover:text-hyouka-sakura transition-colors">
        古典部
      </span>
    </a>

    <div class="flex items-center gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 text-sm text-hyouka-ink-light dark:text-gray-400 
                   hover:text-hyouka-sakura dark:hover:text-pink-300 
                   transition-colors rounded-lg hover:bg-hyouka-sakura/5 dark:hover:bg-pink-900/20"
          >
            {item.label}
          </a>
        ))
      }
      <button id="theme-toggle" class="ml-2 p-2 text-hyouka-ink-light dark:text-gray-400 hover:text-hyouka-gold transition-colors" aria-label="切换主题">
        <svg class="w-5 h-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  // Theme toggle
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const html = document.documentElement;
      html.classList.toggle('dark');
      localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
    });
  }

  // Restore theme
  const savedTheme = localStorage.getItem('theme');
  if (savedTheme) {
    document.documentElement.classList.toggle('dark', savedTheme === 'dark');
  } else {
    document.documentElement.classList.add('dark');
  }
</script>
