---
import Layout from '../../layouts/Layout.astro';
import { getSortedPosts } from '../../data/posts';

const allPosts = getSortedPosts();
---

<Layout title="博客" description="博客文章列表">
  <div class="max-w-4xl mx-auto px-4 pt-24 pb-16">
    <h1 class="hyouka-heading text-2xl mb-8 flex items-center gap-2">
      <span class="w-1 h-5 bg-hyouka-sakura rounded-full inline-block"></span>
      博客文章
    </h1>

    <div class="space-y-4">
      {allPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="block hyouka-card p-5 group">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2 flex-wrap">
                {post.tags.map((tag) => (
                  <span class="hyouka-tag">{tag}</span>
                ))}
              </div>
              <h2 class="font-serif text-lg font-bold text-hyouka-ink dark:text-gray-100 
                         group-hover:text-hyouka-sakura dark:group-hover:text-pink-300 transition-colors mb-2">
                {post.title}
              </h2>
              <p class="text-sm text-hyouka-ink-light dark:text-gray-400 leading-relaxed">
                {post.description}
              </p>
              <p class="text-xs text-hyouka-mist dark:text-gray-600 mt-3">{post.date}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
