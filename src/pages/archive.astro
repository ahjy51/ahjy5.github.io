---
import Layout from "../layouts/Layout.astro";
import { getSortedPosts } from "../data/posts";

const allPosts = getSortedPosts();

// Group posts by year
const postsByYear = allPosts.reduce<Record<string, typeof allPosts>>((acc, post) => {
  const year = post.date.slice(0, 4);
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});
---

<Layout title="归档" description="文章归档">
  <div class="max-w-4xl mx-auto px-4 pt-24 pb-16">
    <h1 class="hyouka-heading text-2xl mb-8 flex items-center gap-2">
      <span class="w-1 h-5 bg-hyouka-sakura rounded-full inline-block"></span>
      归档
    </h1>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 top-0 bottom-0 w-px bg-hyouka-mist/50 dark:bg-gray-700/50"></div>

      {Object.entries(postsByYear).sort(([a], [b]) => Number(b) - Number(a)).map(([year, yearPosts]) => (
        <div class="relative pl-12 mb-8">
          <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full bg-hyouka-sakura border-2 border-white dark:border-gray-950"></div>
          <h2 class="hyouka-heading text-lg">{year}</h2>

          <div class="mt-4 space-y-4">
            {yearPosts.map((post) => (
              <a href={`/blog/${post.slug}`} class="relative pl-0 mb-6 block group">
                <div class="hyouka-card p-4 group-hover:translate-x-1 transition-transform">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="font-medium text-hyouka-ink dark:text-gray-100 group-hover:text-hyouka-sakura transition-colors mb-1">
                        {post.title}
                      </h3>
                      <p class="text-xs text-hyouka-mist dark:text-gray-500">{post.tags.join(' · ')}</p>
                    </div>
                    <span class="text-xs text-hyouka-mist dark:text-gray-600 shrink-0">{post.date.slice(5)}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
